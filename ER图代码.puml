' ============================================
' 图4.2 用户信息表实体图
' ============================================
@startuml 用户实体图
!theme plain
skinparam defaultFontName "Microsoft YaHei"
skinparam defaultFontSize 12

entity "用户" as user {
    * id : BIGINT <<PK>>
    --
    * username : VARCHAR(50) <<UNIQUE>>
    * password : VARCHAR(255)
    phone : VARCHAR(20)
    email : VARCHAR(100)
    nickname : VARCHAR(50)
    avatar : VARCHAR(255)
    * role : VARCHAR(20)
    * create_time : DATETIME
    * update_time : DATETIME
    * deleted : INT
}

@enduml

